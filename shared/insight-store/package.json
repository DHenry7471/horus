{
  "name": "@wutangbanger/horus-insight-store",
  "version": "1.5.0",
  "description": "JSONL-backed persistence for AI agent insights",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@wutangbanger/horus-contracts": "workspace:*",
    "@wutangbanger/claude-agents": "^3.2.0"
  },
  "peerDependencies": {
    "vitest": ">=1.0.0 <5.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": { "optional": true }
  },
  "bin": {
    "horus-ingest": "./dist/ingest.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist"
  }
}
